model Media {
  id         String    @id @default(cuid())
  url        String
  type       MediaType
  caption    String?
  likesCount Int       @default(0)
  userId     String
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Vote {
  id          String   @id @default(cuid())
  eventId     String
  candidateId String
  voterIp     String?
  deviceId    String?
  createdAt   DateTime @default(now())
  candidate   User     @relation("VotesReceived", fields: [candidateId], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, candidateId, voterIp])
  @@index([eventId])
  @@index([candidateId])
}

enum UserRole {
  ADMIN
  CANDIDATE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum EventStatus {
  UPCOMING
  ACTIVE
  FINISHED
}
